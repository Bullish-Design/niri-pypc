# Dense workspace configuration for nested testing
# Expected invariants: 1 output, 5+ workspaces for large payload testing
# Designed for testing larger snapshot payloads and queue behavior

output "DP-1" {
    res 1920x1080
    position 0x0
    scale 1.0
}

workspace "1" {
    output "DP-1"
}

workspace "2" {
    output "DP-1"
}

workspace "3" {
    output "DP-1"
}

workspace "4" {
    output "DP-1"
}

workspace "5" {
    output "DP-1"
}
